# BurnPilot — frontend environment
# Copiar a .env.local y rellenar (nunca subir al repo).
# Usa el proyecto Supabase que ya tienes (Settings → API); no hace falta crear uno nuevo.

# Opcional: mismo origen que en Redirect URLs de Supabase (evita fallos si mezclas localhost y 127.0.0.1).
# VITE_AUTH_SITE_ORIGIN=http://localhost:5173

# API Express (Railway o local). Necesaria para eliminar cuenta desde /settings/account.
VITE_API_URL=http://localhost:3000

# Project URL sola: https://xxxx.supabase.co (no pegues la URL de PostgREST /rest/v1/).
VITE_SUPABASE_URL=
# Publishable key del dashboard (cadena larga sb_publishable_… o legacy anon JWT). Sin < > ni texto de ejemplo.
VITE_SUPABASE_ANON_KEY=

VITE_SENTRY_DSN=
VITE_UMAMI_WEBSITE_ID=
