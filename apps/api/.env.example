# BurnPilot — backend environment
# Copiar a .env y rellenar (nunca subir al repo).
# En local, `src/server.ts` carga este archivo vía dotenv antes de leer la config.

NODE_ENV=development
LOG_LEVEL=info
PORT=3000

ALLOWED_ORIGIN=http://localhost:5173

# Supabase — misma URL y anon key que en apps/web/.env.local (VITE_*)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role: borrado cuenta, webhooks, tablas con RLS bypass
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Stripe — obligatorio en Sprint 5
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=
STRIPE_PRICE_ID_LIFETIME=

# Resend — obligatorio cuando implementemos emails custom
RESEND_API_KEY=
RESEND_FROM_EMAIL=BurnPilot <hello@burnpilot.app>

APP_URL=http://localhost:5173
MARKETING_URL=http://localhost:5173

CRON_SECRET=
SENTRY_DSN=
BETTER_STACK_SOURCE_TOKEN=

# Roadmappilot + sugerencias IA en Herramientas (Anthropic). Solo servidor; nunca en VITE_*.
ANTHROPIC_API_KEY=
# Opcional; por defecto claude-sonnet-4-20250514
ANTHROPIC_MODEL=

# Roadmappilot fase 2 — agente HTTP externo (POST JSON). Ver docs/stackos-spec.md
# STACKOS_AGENT_URL=https://tu-servicio.example/v1/stackos
# STACKOS_AGENT_API_KEY=
# STACKOS_AGENT_TIMEOUT_MS=55000
